# .env.example — Environment variables for Merriman
#
# Copy to .env and fill in the values you need.
# Comments (#) and blank lines are ignored at load time.
#
# .env is loaded by scripts/_common.sh at agent run time via load_secrets().
# MCP server API keys belong in .mcp.json (gitignored) — not here.
# See docs/adding-mcp-tools.md.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Required for the omp and claude runtimes.
ANTHROPIC_API_KEY=

# Other providers (only needed if you switch runtimes or models):
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# ── Notification Channels ─────────────────────────────────────────────────────
# Fill in the credentials for each channel you want to use.
# Configure which channels each agent uses in agents/<name>/agent.yml.
# Configure which channels are active globally in config.yml.

# Telegram
# Get a bot token from @BotFather: https://core.telegram.org/bots#botfather
# Find your chat ID by sending /start to @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord
# Create a webhook: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# ntfy (push notifications — self-hosted or ntfy.sh)
# https://ntfy.sh/docs/publish/
NTFY_TOPIC=
# NTFY_URL=    # Leave blank to use https://ntfy.sh (the public server)

# Email (via SMTP)
# Format: smtp://user:password@host:port
SMTP_URL=
NOTIFY_EMAIL=

# ── Infrastructure ────────────────────────────────────────────────────────────
# OpenMemory — long-term semantic memory (runs via docker-compose.yml)
# Default port matches docker-compose.yml. Change if you remap it.
MEMORY_URL=http://localhost:2444

# OpenMemory API key — set a strong random string here.
# Use this same value as x-api-key in .mcp.json.
# Generate one: openssl rand -hex 32
OM_API_KEY=

# Embedding provider for OpenMemory vector search.
# Options: openai | gemini | aws | ollama | local | synthetic
# "local" uses a bundled model (no API key). "synthetic" disables semantic search.
OM_EMBEDDINGS=openai

# Performance tier for OpenMemory.
# Options: hybrid (recommended) | fast | smart | deep
OM_TIER=hybrid

# External port OpenMemory listens on (must match MEMORY_URL above).
MEMORY_PORT=2444
