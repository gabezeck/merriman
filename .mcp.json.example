{
  "_comment": "Only openmemory is required. All other servers are examples — add, remove, or swap for whatever services you use. See docs/adding-mcp-tools.md for guidance.",
  "mcpServers": {
    "openmemory": {
      "_comment": "Required. OpenMemory — long-term semantic memory (CaviraOSS/OpenMemory, self-hosted).",
      "_setup": "Clone and start via docker-compose.yml. See docs/getting-started.md.",
      "_key": "x-api-key must match OM_API_KEY in your .env file.",
      "type": "http",
      "url": "http://localhost:2444/mcp",
      "headers": {
        "content-type": "application/json",
        "accept": "application/json, text/event-stream",
        "x-api-key": "YOUR_OM_API_KEY"
      }
    },

    "todoist": {
      "_comment": "Example: Todoist task manager. Replace with any task MCP you prefer.",
      "_docs": "https://todoist.com/help/articles/use-mcp-with-todoist",
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://ai.todoist.net/mcp"]
    },

    "google-calendar": {
      "_comment": "Example: Google Calendar. Replace with any calendar MCP you prefer.",
      "_docs": "https://github.com/cocal/google-calendar-mcp",
      "command": "npx",
      "args": ["-y", "@cocal/google-calendar-mcp"],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "/path/to/gcp-oauth.keys.json"
      }
    },

    "gmail": {
      "_comment": "Example: Gmail. Replace with any email MCP you prefer.",
      "_docs": "https://github.com/google-research/google-research/tree/master/gmail_mcp",
      "command": "npx",
      "args": ["-y", "@gongrzhe/server-gmail-autoauth-mcp"]
    },

    "guardian": {
      "_comment": "Example: The Guardian news. Replace with any news MCP you prefer. Free API key.",
      "_docs": "https://open-platform.theguardian.com/access/",
      "command": "npx",
      "args": ["guardian-mcp-server"],
      "env": {
        "GUARDIAN_API_KEY": "YOUR_GUARDIAN_API_KEY"
      }
    },

    "open-meteo": {
      "_comment": "Example: Weather forecasts. No API key required.",
      "_docs": "https://open-meteo.com",
      "command": "npx",
      "args": ["-y", "-p", "open-meteo-mcp-server", "open-meteo-mcp-server"]
    }
  }
}
